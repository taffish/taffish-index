          "set -eu; d=/tmp/taf-bcftools-plugin-$$; mkdir -p \"$d\"; printf '##fileformat=VCFv4.2\n##contig=<ID=chr1,length=100>\n##FORMAT=<ID=GT,Number=1,Type=String,Description=Genotype>\n#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\tFORMAT\tS1\nchr1\t10\t.\tA\tG\t50\tPASS\t.\tGT\t0/1\n' > \"$d/in.vcf\"; bcftools +fill-tags \"$d/in.vcf\" -Ou -- -t AC,AN | bcftools query -f '%INFO/AC\t%INFO/AN\n' > \"$d/out.tsv\"; test \"$(cat \"$d/out.tsv\")\" = \"$(printf '1\t2')\"; rm -rf \"$d\"",
          "set -eu; d=/tmp/taf-bcftools-index-$$; mkdir -p \"$d\"; printf '##fileformat=VCFv4.2\n##contig=<ID=chr1,length=100>\n#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\nchr1\t10\t.\tA\tG\t50\tPASS\t.\n' > \"$d/in.vcf\"; bgzip -c \"$d/in.vcf\" > \"$d/in.vcf.gz\"; tabix -p vcf \"$d/in.vcf.gz\"; bcftools view -H \"$d/in.vcf.gz\" | grep -F 'chr1' >/dev/null; test -s \"$d/in.vcf.gz.tbi\"; rm -rf \"$d\"",
          "set -eu; d=/tmp/taf-bcftools-plot-$$; mkdir -p \"$d\"; printf '##fileformat=VCFv4.2\n##contig=<ID=chr1,length=100>\n#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\nchr1\t10\t.\tA\tG\t50\tPASS\t.\n' > \"$d/in.vcf\"; bcftools stats \"$d/in.vcf\" > \"$d/stats.vchk\"; plot-vcfstats -P -p \"$d/plots\" \"$d/stats.vchk\"; test -s \"$d/plots/plot.py\"; find \"$d/plots\" -type f -name '*.png' -size +0c | grep -q .; rm -rf \"$d\"",
          "python -c 'import gffutils, matplotlib, numpy'",
          "{ roh-viz -h 2>&1 || true; } | grep -F 'HTML/JavaScript visualization' >/dev/null && { run-roh.pl -h 2>&1 || true; } | grep -F 'convenience wrapper' >/dev/null",
          "set -eu; d=/tmp/taf-bcftools-roh-$$; mkdir -p \"$d\"; printf '##fileformat=VCFv4.2\n##contig=<ID=chr1,length=500000>\n##FORMAT=<ID=GT,Number=1,Type=String,Description=Genotype>\n#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\tFORMAT\tS1\nchr1\t100\t.\tA\tG\t50\tPASS\t.\tGT\t0/1\nchr1\t200000\t.\tC\tT\t50\tPASS\t.\tGT\t1/1\n' > \"$d/in.vcf\"; printf '# The command line was: bcftools roh\nRG\tS1\tchr1\t1\t250000\t249999\t2\t50\n' > \"$d/roh.txt\"; roh-viz -c 1 -i \"$d/roh.txt\" -v \"$d/in.vcf\" -l 0 -o \"$d/out.html\"; test -s \"$d/out.html\"; grep -F '<!DOCTYPE html>' \"$d/out.html\" >/dev/null; rm -rf \"$d\"",
          "printf 'ok\n' | gzip -c | gunzip -c | grep -Fx 'ok' >/dev/null",
