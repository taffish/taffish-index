          "bcftools --help 2>&1 | grep -F 'Program: bcftools' >/dev/null",
          "bcftools --version 2>&1 | grep -Fx 'bcftools 1.24' >/dev/null && bcftools --version 2>&1 | grep -Fx 'Using htslib 1.24' >/dev/null",
          "bcftools polysomy -h 2>&1 | grep -F 'bcftools polysomy' >/dev/null && bcftools cnv -h 2>&1 | grep -F 'bcftools cnv' >/dev/null",
          "bcftools norm -h 2>&1 | grep -F -- '--no-realign' >/dev/null && bcftools csq -h 2>&1 | grep -F -- '--greedy' >/dev/null",
