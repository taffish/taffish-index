        "test": [
          "NGenomeSyn -help 2>&1 | grep -F 'Version:1.43' >/dev/null && GetTwoGenomeSyn -help 2>&1 | grep -F 'Version:1.43' >/dev/null && perl -MSVG -MSwitch -e 1",
          "mkdir -p /tmp/taf-ngenomesyn-plot && cd /tmp/taf-ngenomesyn-plot && printf 'chr1\\t1\\t1000\\nchr2\\t1\\t800\\n' > a.len && printf 'chrA\\t1\\t900\\nchrB\\t1\\t700\\n' > b.len && printf 'chr1\\t100\\t350\\tchrA\\t120\\t360\\tfill=#66c2a5\\nchr2\\t80\\t260\\tchrB\\t90\\t240\\tfill=#fc8d62\\n' > ab.link && printf 'SetParaFor = global\\nGenomeInfoFile1=a.len\\nGenomeInfoFile2=b.len\\nLinkFileRef1VsRef2=ab.link\\nSetParaFor = Genome1\\nGenomeName=A\\nSetParaFor = Genome2\\nGenomeName=B\\n' > in.conf && NGenomeSyn -InConf in.conf -OutPut out >/tmp/taf-ngenomesyn-plot.log 2>&1 && test -s out.svg && test -s out.png && grep -F '<svg' out.svg >/dev/null",
          "mkdir -p /tmp/taf-ngenomesyn-helper && cd /tmp/taf-ngenomesyn-helper && printf 'q1\\t1000\\t10\\t120\\t+\\tt1\\t2000\\t20\\t130\\t110\\t110\\t60\\nq2\\t1000\\t10\\t40\\t-\\tt2\\t2000\\t300\\t330\\t30\\t30\\t60\\n' > toy.paf && GetTwoGenomeSyn Paf2Link toy.paf 50 toy.link && grep -F 'q1' toy.link >/dev/null && ! grep -F 'q2' toy.link >/dev/null",
          "convert -version | grep -F 'ImageMagick' >/dev/null && rsvg-convert --version >/dev/null && minimap2 --version >/dev/null && case \"$(nucmer -V)\" in 4.*) true;; *) exit 1;; esac && command -v delta-filter >/dev/null && command -v show-coords >/dev/null"
