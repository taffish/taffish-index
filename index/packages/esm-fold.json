      "smoke": {
        "backend": "docker",
        "timeout": 300,
        "exist": [
          "esm-fold",
          "python",
          "python3",
          "pip",
          "nvcc"
        ],
        "test": [
          "esm-fold -h | grep -F 'Path to input FASTA file' >/dev/null",
          "python -c 'import importlib.metadata as m; assert m.version(\"fair-esm\") == \"2.0.0\"'",
          "python -c 'import torch; assert torch.__version__.startswith(\"1.12.1\")'",
          "python -c 'import esm, openfold, deepspeed, dllogger, tree; assert callable(esm.pretrained.esmfold_v1)'",
          "python -c 'from pathlib import Path; assert \"model = model.float()\" in Path(\"/opt/esm/scripts/esmfold_inference.py\").read_text()'",
          "python -c 'from pathlib import Path; from esm.data import read_fasta; p=Path(\"/tmp/taf-esm-fold-smoke.fa\"); p.write_text(\">toy\\nMKT\\n\"); assert list(read_fasta(p)) == [(\"toy\", \"MKT\")]'"
        ],
