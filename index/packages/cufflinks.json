        }
      },
      "smoke": {
        "backend": "docker",
        "timeout": 120,
        "exist": [
          "cufflinks",
          "cuffcompare",
          "cuffmerge",
          "cuffquant",
          "cuffdiff",
          "cuffnorm",
          "gffread",
          "gtf_to_sam",
          "python3",
          "sort"
        ],
        "test": [
          "{ cufflinks 2>&1 || true; } | grep -F 'cufflinks v2.2.1' >/dev/null",
          "{ cuffcompare 2>&1 || true; } | grep -F 'cuffcompare v2.2.1' >/dev/null",
          "cuffmerge --help 2>&1 | grep -F 'cuffmerge takes two or more Cufflinks GTF files' >/dev/null",
          "{ cuffquant 2>&1 || true; } | grep -F 'cuffquant v2.2.1' >/dev/null",
          "{ cuffdiff 2>&1 || true; } | grep -F 'cuffdiff v2.2.1' >/dev/null",
          "{ cuffnorm 2>&1 || true; } | grep -F 'cuffnorm v2.2.1' >/dev/null",
          "{ gffread -h 2>&1 || true; } | grep -F 'Usage:' >/dev/null",
          "{ gtf_to_sam 2>&1 || true; } | grep -F 'gtf_to_sam v2.2.1' >/dev/null",
          "python3 -m py_compile $(command -v cuffmerge)",
          "mkdir -p /tmp/taf-cufflinks-test && cd /tmp/taf-cufflinks-test && printf 'chr1\\tTAF\\texon\\t1\\t100\\t.\\t+\\t.\\tgene_id \"g1\"; transcript_id \"t1\";\\n' > tiny.gtf && gffread tiny.gtf -o tiny.out.gff && test -s tiny.out.gff && cuffcompare tiny.gtf >/tmp/taf-cufflinks-cuffcompare.log 2>&1 && test -s cuffcmp.combined.gtf && grep -F 'transcript_id' cuffcmp.combined.gtf >/dev/null"
        ],
