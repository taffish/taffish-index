      "container": {
        "image": "ghcr.io/taffish/cufflinks:2.2.1-r1",
        "dockerfile": "docker/Dockerfile",
        "image_tag": "2.2.1-r1",
        "image_tag_matches_version": true,
        "digest": "sha256:6555ab08b7fd7e59b0260c1018d1ece80ad83451079fae94bb1813ad393888c5",
        "platforms": [
