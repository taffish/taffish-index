        ],
        "test": [
          "EVidenceModeler --version 2>&1 | grep -F 'EVidenceModeler-v2.1.0' >/dev/null",
          "EVidenceModeler --help 2>&1 | grep -F 'Evidence Modeler' >/dev/null",
          "ParaFly 2>&1 | grep -F 'ParaFly' >/dev/null",
          "perl -MDB_File -MURI::Escape -MBio::SearchIO -e 1",
          "test \"$EUK_MODULES\" = '/opt/evidencemodeler/PerlLib' && prepare_Jigsaw_formats.pl -h 2>&1 | grep -F -- '--template_gff3_file' >/dev/null && gff3_genes_to_gff2.pl 2>&1 | grep -F 'usage' >/dev/null",
          "python -c 'import sys; assert sys.version_info[0] == 3'",
          "mkdir -p /tmp/taf-evidencemodeler-smoke && cd /tmp/taf-evidencemodeler-smoke && cp -a /opt/evidencemodeler/testing/. . && EVidenceModeler --sample_id smalltest --genome genome.fasta --weights weights.txt --gene_predictions gene_predictions.gff3 --protein_alignments protein_alignments.gff3 --transcript_alignments transcript_alignments.gff3 --segmentSize 100000 --overlapSize 10000 --CPU 1 >/tmp/taf-evidencemodeler-smoke.log 2>&1 && test -s smalltest.EVM.gff3 && test -s smalltest.EVM.pep && test -s smalltest.EVM.cds && test -s smalltest.EVM.bed && grep -F 'evm.TU' smalltest.EVM.gff3 >/dev/null"
        ],
