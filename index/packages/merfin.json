          "kmer"
        ],
        "keywords": [
          "merfin",
          "meryl",
          "k-mer",
          "assembly-polishing",
          "variant-filtering",
          "qv",
          "completeness",
          "genome-evaluation"
        ],
        "summary": "Merfin improves variant filtering, assembly evaluation, and polishing through k-mer validation.",
        "description": "Merfin improves variant filtering, assembly evaluation, and polishing through k-mer validation."
      },
      "paths": {
        "main": "src/main.taf",
        "help": "docs/help.md",
        "dockerfile": "docker/Dockerfile"
      },
      "container": {
        "image": "ghcr.io/taffish/merfin:1.1-r1",
        "dockerfile": "docker/Dockerfile",
        "image_tag": "1.1-r1",
        "image_tag_matches_version": true,
        "digest": "sha256:e060c915221defd44a1a32d872443ae2116020bae0737efc0666d4f12dd0e063",
        "platforms": [
          "linux/amd64",
          "linux/arm64"
        ],
        "platform_digests": {
          "linux/amd64": "sha256:5052af3751b4fb62baf6fccb18c681a29a524284c69178bef57c312f320da48e",
          "linux/arm64": "sha256:ee64eb969a261c38e4f1f75ea3ff5daaa2d497302fff75f56e84b307f466a8ff"
        }
      },
      "smoke": {
        "backend": "docker",
        "timeout": 180,
        "exist": [
          "merfin",
          "meryl",
          "gzip",
          "bzip2",
          "xz"
        ],
        "test": [
          "test \"$(cat /usr/local/share/doc/merfin/VERSION)\" = '1.1'",
          "test \"$(cat /usr/local/share/doc/merfin/MERYL_COMMIT)\" = 'd8f336f791b92c2a265e70bba9f995621b67d195'",
          "merfin 2>&1 | grep -F 'usage:' >/dev/null",
          "merfin 2>&1 | grep -F -- '-loose (least conservative)' >/dev/null",
          "meryl -h 2>&1 | grep -F 'COMMANDS:' >/dev/null",
          "ldd \"$(command -v merfin)\" | grep -F 'libgomp' >/dev/null",
          "mkdir -p /tmp/taf-merfin-smoke && cd /tmp/taf-merfin-smoke && printf '>toy\\nACGTACGTACGTACGTACGTACGTACGTACGT\\n' > seq.fa && meryl count memory=0.1 threads=1 k=21 seq.fa output read.meryl >/dev/null 2> meryl.log && test -d read.meryl && meryl histogram read.meryl > read.hist && test -s read.hist && merfin -hist -sequence seq.fa -readmers read.meryl -peak 1 -output merfin.hist -threads 1 > merfin.out 2> merfin.log && test -s merfin.hist && grep -F 'Merfin QV*' merfin.log >/dev/null && grep -F 'Bye!' merfin.log >/dev/null"
        ],
        "status": "passed",
        "checked_at": "2026-05-23T05:22:32Z",
        "backend_used": "docker"
      },
