      "smoke": {
        "backend": "docker",
        "timeout": 180,
        "exist": [
          "multiqc",
          "python",
          "python3"
        ],
        "test": [
          "test \"$(python -c 'import importlib.metadata; print(importlib.metadata.version(\"multiqc\"))')\" = '1.35'",
          "multiqc --version 2>&1 | grep -F '1.35' >/dev/null",
          "multiqc --help 2>&1 | grep -F 'Usage:' >/dev/null && multiqc --help 2>&1 | grep -F 'MultiQC' >/dev/null",
          "python -c 'import multiqc, plotly, pyarrow, polars, yaml, rich_click, pydantic'",
          "mkdir -p /tmp/taf-multiqc-custom && cd /tmp/taf-multiqc-custom && printf 'id: \"taf_custom_metrics\"\\nsection_name: \"TAFFISH Custom Metrics\"\\ndescription: \"Minimal custom content smoke test.\"\\nplot_type: \"bargraph\"\\npconfig:\\n  id: \"taf_custom_bargraph\"\\n  title: \"TAFFISH Custom Metrics\"\\n  ylab: \"Count\"\\ndata:\\n  sample_a:\\n    metric_a: 12\\n    metric_b: 4\\n  sample_b:\\n    metric_a: 8\\n    metric_b: 9\\n' > metrics_mqc.yaml && multiqc . --outdir out --data-format json --force --quiet && test -s out/multiqc_report.html && test -s out/multiqc_data/multiqc_data.json && grep -F 'TAFFISH Custom Metrics' out/multiqc_report.html >/dev/null && grep -F 'taf_custom_bargraph' out/multiqc_data/multiqc_data.json >/dev/null",
          "python -c 'import os, plotly.graph_objects as go; fig = go.Figure(data=[go.Bar(x=[\"sample\"], y=[1])]); fig.write_image(\"/tmp/taf-multiqc-kaleido.png\"); assert os.path.getsize(\"/tmp/taf-multiqc-kaleido.png\") > 0'"
        ],
        "status": "passed",
