        ],
        "platform_digests": {
          "linux/amd64": "sha256:ac504fea1472f77839d36ee341137b346019f1d1c7f101bba8f39e287b415756"
        }
      },
      "smoke": {
        "backend": "docker",
        "timeout": 180,
        "exist": [
          "meryl",
          "meryl-lookup",
          "meryl-import",
          "meryl-analyze",
          "meryl-simple",
          "position-lookup",
          "gzip",
          "bzip2",
          "xz",
          "bash"
        ],
        "test": [
          "test \"$(cat /usr/local/share/doc/meryl/VERSION)\" = '1.4.1'",
          "meryl --version 2>&1 | grep -F 'meryl 1.4.1' >/dev/null",
          "meryl -h 2>&1 | grep -F 'COMMANDS:' >/dev/null",
          "meryl-lookup 2>&1 | grep -F 'usage:' >/dev/null",
          "meryl-import 2>&1 | grep -F 'usage:' >/dev/null",
          "meryl-simple 2>&1 | grep -F 'usage:' >/dev/null",
          "meryl-analyze 2>&1 | grep -F 'usage:' >/dev/null",
          "ldd \"$(command -v meryl)\" | grep -F 'libgomp' >/dev/null",
          "mkdir -p /tmp/taf-meryl-smoke && cd /tmp/taf-meryl-smoke && printf '>toy\\nACGTACGTACGTACGTACGTACGTACGTACGT\\n' > seq.fa && meryl k=21 memory=0.1 threads=1 count seq.fa output seq.meryl >/dev/null 2> meryl.log && test -d seq.meryl && meryl histogram seq.meryl > seq.hist && grep -E '^6[[:space:]]+2$' seq.hist >/dev/null && meryl statistics seq.meryl > seq.stats && grep -F 'distinct                    2' seq.stats >/dev/null && meryl print seq.meryl > seq.print && grep -F 'ACGTACGTACGTACGTACGTA' seq.print >/dev/null"
        ],
        "status": "passed",
