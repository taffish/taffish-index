        "summary": "Meryl is a genomic k-mer counter and sequence utility used by Merqury and related assembly-evaluation workflows.",
        "description": "Meryl is a genomic k-mer counter and sequence utility used by Merqury and related assembly-evaluation workflows."
      },
      "paths": {
        "main": "src/main.taf",
        "help": "docs/help.md",
        "dockerfile": "docker/Dockerfile"
      },
      "container": {
        "image": "ghcr.io/taffish/meryl:1.4.1-r1",
        "dockerfile": "docker/Dockerfile",
        "image_tag": "1.4.1-r1",
        "image_tag_matches_version": true,
        "digest": "sha256:8babae12621af8b372d2d207bde1aed0b8539753bf9a61bc74f0900d7f5355ad",
