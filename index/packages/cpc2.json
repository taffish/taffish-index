          "mkdir -p /tmp/taf-cpc2-test && cd /tmp/taf-cpc2-test && printf '>coding\\nATGGCCATTGTAATGGGCCGCTGAAAGGGTGCCCGATAG\\n>noncoding\\nTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTT\\n' > input.fa && CPC2.py -i input.fa -o cpc2-out >/dev/null && test -s cpc2-out.txt && head -n 1 cpc2-out.txt | grep -F 'coding_probability' >/dev/null && grep -E 'coding|noncoding' cpc2-out.txt >/dev/null",
